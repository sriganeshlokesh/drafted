# Base URL for the forged evaluation API (POST /v1/evaluations).
#
# Leave blank for local dev: Vite proxies /v1 to http://localhost:8080
# (see vite.config.ts), so requests stay same-origin and avoid CORS.
#
# Set to the deployed backend origin for non-proxied / production builds
# (that origin must then allow CORS from this app).
VITE_API_BASE_URL=

# Base URL for the keysmith auth API (login/signup/refresh + cookies).
#
# Leave blank for local dev: Vite proxies /auth to http://localhost:8080
# (keysmith; forged runs on 8081 locally — see vite.config.ts).
#
# Set to the deployed keysmith origin for production builds. Note: the
# refresh cookie is SameSite=Lax, so the SPA and keysmith must be same-site
# (e.g. app.<domain> and auth.<domain>) — separate *.up.railway.app domains
# will NOT share cookies.
VITE_AUTH_BASE_URL=
