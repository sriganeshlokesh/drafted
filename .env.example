# Base URL for the forged evaluation API (POST /v1/evaluations).
#
# Leave blank for local dev: Vite proxies /v1 to http://localhost:8080
# (see vite.config.ts), so requests stay same-origin and avoid CORS.
#
# Set to the deployed backend origin for non-proxied / production builds
# (that origin must then allow CORS from this app).
VITE_API_BASE_URL=
